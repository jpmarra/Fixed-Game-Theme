{% if section.settings.hero_logo %}
  <div class="product-grid__hero">
    {{ section.settings.hero_logo | image_url: width: 800 | image_tag }}
  </div>
{% endif %}

<div class="product-grid" style="--grid-columns: {{ section.settings.columns_desktop }}">
  {% assign grid_collection = section.settings.collection | default: collections.all %}
  {% paginate grid_collection.products by 24 %}
    {% for product in grid_collection.products %}
      {% render 'product-card', product: product %}
    {% endfor %}

    {% if paginate.pages > 1 %}
      <div class="product-grid__pagination">
        {{ paginate | default_pagination }}
      </div>
    {% endif %}
  {% endpaginate %}
</div>

{% stylesheet %}
  .product-grid__hero {
    display: flex;
    justify-content: center;
    padding: 1rem 0 calc(1rem + var(--header-height, 4rem));
  }
  .product-grid__hero img {
    max-width: min(400px, 100%);
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), minmax(0, 0.8fr));
    justify-content: center;
    gap: 1.5rem;
    max-width: 80%;
    margin: 0 auto;
  }
  @media (max-width: 999px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 639px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
  .product-grid__pagination {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem 0;
  }
  .product-grid__pagination a {
    margin: 0 0.25rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product_grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "image_picker",
      "id": "hero_logo",
      "label": "t:labels.hero_logo"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:labels.columns_desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    }
  ],
  "presets": [
    {
      "name": "t:general.product_grid"
    }
  ]
}
{% endschema %}

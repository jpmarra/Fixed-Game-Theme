<footer>
  {% if section.settings.logo %}
    <div class="footer__logo">
      <a href="{{ section.settings.logo_url | default: routes.root_url }}" target="_blank" rel="noopener">
        {{ section.settings.logo | image_url: width: section.settings.logo_max_width | image_tag }}
      </a>
    </div>
  {% endif %}
</footer>

{% stylesheet %}
  footer {
    margin-top: auto;
    padding: 2rem 0;
    font-size: 0.75rem;
  }
  .footer__logo {
    display: flex;
    justify-content: center;
  }
  .footer__logo img {
    max-width: 100%;
    height: auto;
  }
  footer a {
    text-decoration: none;
    color: var(--color-foreground);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "url",
      "id": "logo_url",
      "label": "t:labels.logo_url"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "t:labels.logo_max_width",
      "default": 150
    }
  ]
}
{% endschema %}

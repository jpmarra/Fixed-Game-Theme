<header>
  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  </div>

  {% if template.name != 'index' %}
    <div class="header__logo">
      <a href="{{ routes.root_url }}">
        {% if section.settings.logo %}
          {{ section.settings.logo | image_url: width: section.settings.logo_max_width | image_tag }}
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>
  {% endif %}

  <div class="header__icons">
    <button data-cart-drawer-open aria-label="{{ 'general.accessibility.close' | t }}">
      <span class="header__cart-count" data-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</span>
      {{ 'icon-cart.svg' | inline_asset_content }}
    </button>
  </div>
</header>

{% stylesheet %}
  header {
    --header-height: 4rem;
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1.5rem;
  }
  .header__logo a {
    text-decoration: none;
    color: var(--color-foreground);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 1.25rem;
    font-weight: 700;
  }
  .header__logo img {
    max-height: 3rem;
    width: auto;
    object-fit: contain;
  }
  .header__menu,
  .header__icons {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .header__menu a {
    text-decoration: none;
    color: var(--color-foreground);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  header button[data-cart-drawer-open] {
    position: relative;
    background: none;
    border: none;
    padding: 0;
    color: var(--color-foreground);
    cursor: pointer;
    display: flex;
    align-items: center;
  }
  header button[data-cart-drawer-open]:hover {
    background: none;
    color: var(--color-accent);
  }
  header svg {
    width: 2rem;
  }
  .header__cart-count {
    position: absolute;
    top: -0.5rem;
    right: -0.5rem;
    background: var(--color-accent);
    color: var(--color-background);
    font-size: 0.625rem;
    width: 1rem;
    height: 1rem;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "t:labels.logo_max_width",
      "default": 200
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
  ]
}
{% endschema %}
